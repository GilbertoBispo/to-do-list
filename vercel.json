{
  "version": 2,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "frontend/public/**", "use": "@vercel/static" }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/backend/**"
    },
    {
      "source": "/",
      "destination": "frontend/public/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/public/$1"
    }
  ]
}